LUCA_SAAS=1
LUCA_PORT=21000
DATA_DIR=/home/ubuntu/lucawriter-data

# 与 Coobox 的 LUCA_SAAS_SECRET 完全一致
LUCA_SAAS_SECRET=replace-with-a-long-random-secret
# 与 Coobox 的 LUCA_INTERNAL_SECRET 完全一致
LUCA_INTERNAL_SECRET=replace-with-another-long-random-secret

LUCA_AI_GATEWAY=http://127.0.0.1:8000/api/ai/v1
LUCA_AI_MODEL=deepseek-v4-flash
LUCA_COOBOX_INTERNAL=http://127.0.0.1:8000
LUCA_WALLET_URL=/me/wallet
LUCA_TENANT_QUOTA_MB=100
LUCA_HEAVY_CONCURRENCY=1
