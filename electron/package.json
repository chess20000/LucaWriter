{
  "name": "lucawriter",
  "version": "1.1.3",
  "description": "LucaWriter - AI写作搭档",
  "main": "main.js",
  "author": "LucaWriter",
  "license": "Apache-2.0",
  "_releaseArtifactNameComment": "Keep installer artifact names versionless. Landing uses /releases/latest/download/LucaWriter-Setup.exe and LucaWriter-mac-${arch}.dmg fixed links, so do not add ${version} back to artifactName.",
  "scripts": {
    "icons": "set LUCA_ICON_SCOPE=electron&& python make_icon.py",
    "prebuild": "npm run icons",
    "prebuild:dir": "npm run icons",
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "build:mac": "electron-builder --mac",
    "build:mac:dir": "electron-builder --mac --dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.lucawriter.app",
    "productName": "LucaWriter",
    "copyright": "Copyright © 2026 LucaWriter",
    "directories": {
      "output": "../release/v1.1.3"
    },
    "files": [
      "main.js",
      "preload.js",
      "browser-preload.js",
      "loading.html",
      "browser.html",
      "package.json",
      "loading_icon.png",
      "icon-loading.png",
      "icon.png",
      "icon.ico",
      "tray-icon.png"
    ],
    "extraResources": [
      {
        "from": "dist-backend/LucaWriterBackend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "dist-builtin",
        "to": "builtin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../local_llm",
        "to": "local_llm",
        "filter": [
          "**/*",
          "!models/**",
          "!*.md"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "LucaWriter-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LucaWriter",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerLanguages": ["zh_CN"],
      "language": 2052,
      "include": "installer.nsh"
    },
    "mac": {
      "icon": "../build_macos/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "LucaWriter-mac-${arch}.${ext}",
      "extendInfo": {
        "CFBundleDocumentTypes": [],
        "NSRequiresAquaSystemAppearance": false
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "../build_macos/entitlements.mac.plist",
      "entitlementsInherit": "../build_macos/entitlements.mac.plist"
    },
    "dmg": {
      "title": "LucaWriter ${version}",
      "icon": "../build_macos/icon.icns",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },
    "asar": true
  }
}
